# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=8h

# SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=your_password_here
DB_NAME=open_badges

# Microsoft 365 / Graph API (email via shared mailbox)
MS365_TENANT_ID=your_tenant_id
MS365_CLIENT_ID=your_client_id
MS365_CLIENT_SECRET=your_client_secret
MS365_USER_ID=your_user_id
MS365_SHARED_MAILBOX=badges@tudominio.com

# App public URL (for email links)
APP_URL=http://localhost:3000
