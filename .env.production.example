# =============================================
# Open Badges 3.0 Issuer — Production Config
# =============================================

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://badges.tudominio.com
APP_URL=https://badges.tudominio.com

# JWT (generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CAMBIAR_POR_UN_SECRET_ALEATORIO_DE_64_CARACTERES
JWT_EXPIRES_IN=8h

# SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_USER=BadgesAppUser
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO
DB_NAME=CEPBadges

# Microsoft 365 / Graph API (email via shared mailbox)
# Registrar app en Azure AD > App registrations
# Permisos: Mail.Send (Application) — requiere admin consent
MS365_TENANT_ID=your_tenant_id
MS365_CLIENT_ID=your_client_id
MS365_CLIENT_SECRET=your_client_secret
MS365_USER_ID=your_user_id_or_upn
MS365_SHARED_MAILBOX=badges@tudominio.com
